{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/crawler/layout,_N_T_/crawler/page,_N_T_/crawler"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/crawler/__PAGE__",
    "/crawler",
    "/_index",
    "/_head"
  ]
}